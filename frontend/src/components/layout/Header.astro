---
import LeadPopup from './LeadPopup.vue';
---

<header class="header">

  <div class="container">

    <div class="header__wrapper">

      <!-- LOGO -->

      <a
        href="/"
        class="header__logo"
        aria-label="На главную"
      >
        01вкладка<span>.рф</span>
      </a>

      <!-- ACTIONS -->

      <div class="header__actions">

        <a
          href="https://t.me/yourusername"
          target="_blank"
          rel="noopener noreferrer"
          class="header__telegram"
          aria-label="Написать в Telegram"
        >
          telegram
        </a>

        <button
          class="header__button"
          data-popup
          type="button"
          aria-label="Обсудить проект"
        >
          обсудить проект
        </button>

      </div>

    </div>

  </div>

</header>

<!-- POPUP -->

<LeadPopup client:load />

<script is:inline>
  document.addEventListener('click', (e) => {

    const trigger = e.target.closest('[data-popup]');

    if (!trigger) return;

    e.preventDefault();

    window.dispatchEvent(
      new Event('open-popup')
    );

  });
</script>