---
import footerMascot from '@assets/images/footer_mascot.webp';
---

<section class="footer-cta">

  <div class="footer-cta__noise"></div>

  <div class="container">

    <div class="footer-cta__panel">

      <!-- MASCOT -->

      <div class="footer-cta__mascot">

        <img
          src={footerMascot.src}
          alt=""
          loading="lazy"
          decoding="async"
        />

      </div>

      <!-- LEFT -->

      <div class="footer-cta__left">

        <span class="footer-cta__label">
          digital-студия
        </span>

        <h2 class="footer-cta__title">
          ГОТОВЫ<br />
          ОТКРЫТЬ<br />
          СВОЮ ВКЛАДКУ?
        </h2>

        <p class="footer-cta__description">
          Делаем digital-проекты,
          которые ощущаются как продукт,
          а не очередной шаблонный сайт.
        </p>

        <div class="footer-cta__actions">

          <a
            href="#"
            class="footer-cta__button footer-cta__button--primary"
          >
            обсудить проект
          </a>

          <a
            href="#"
            class="footer-cta__button footer-cta__button--secondary"
          >
            смотреть кейсы
          </a>

        </div>

      </div>

      <!-- RIGHT -->
    <div class="footer-cta__right">

      <!-- CONTACTS -->

      <div class="footer-cta__info">

        <div class="footer-cta__group">

          <span class="footer-cta__caption">
            телефон
          </span>

          <a
            href="tel:88005553535"
            class="footer-cta__contact"
          >
            8 800 555 35 35
          </a>

        </div>

        <div class="footer-cta__group">

          <span class="footer-cta__caption">
            email
          </span>

          <a
            href="mailto:novaya@01vkladka.ru"
            class="footer-cta__contact"
          >
            novaya@01вкладка.рф
          </a>

        </div>

      </div>

      <!-- MESSENGERS -->

      <div class="footer-cta__links">

        <span class="footer-cta__caption">
          месседжеры
        </span>

        <div class="footer-cta__nav">

          <a href="#">
            Телеграм
          </a>

          <a href="#">
            Вконтакте
          </a>

          <a href="#">
            Ватсапп
          </a>

        </div>

      </div>

      <!-- NAVIGATION -->

      <div class="footer-cta__links">

        <span class="footer-cta__caption">
          навигация
        </span>

        <div class="footer-cta__nav">

          <a href="#projects">
            проекты
          </a>

          <a href="#services">
            услуги
          </a>

          <a href="#process">
            процесс
          </a>

          <a href="#pricing">
            цены
          </a>

          <a href="#contacts">
            контакты
          </a>

        </div>

      </div>

</div>

    </div>

    <!-- BOTTOM -->

    <div class="footer-cta__bottom">

      <span>
        01вкладка.рф © 2026
      </span>

      <span>
        сайты, которые не закрывают
      </span>

      <a href="#">
        политика конфиденциальности
      </a>

    </div>

  </div>

</section>