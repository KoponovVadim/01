---
import footerMascot from '@assets/images/footer_mascot.webp';
---

<section class="footer-cta" id="contacts">

  <div class="footer-cta__noise"></div>

  <div class="container">

    <div class="footer-cta__panel">

      <!-- MASCOT -->

      <div class="footer-cta__mascot">

        <img
          src={footerMascot.src}
          alt=""
          loading="lazy"
          decoding="async"
        />

      </div>

      <!-- LEFT -->

      <div class="footer-cta__left">

        <span class="footer-cta__label">
          digital-студия
        </span>

        <h2 class="footer-cta__title">
          ГОТОВЫ<br />
          ОТКРЫТЬ<br />
          СВОЮ ВКЛАДКУ?
        </h2>

        <p class="footer-cta__description">
          Делаем digital-проекты
          с продуктовой логикой,
          сильным UX и точной подачей.
        </p>

        <div class="footer-cta__actions">

          <button
            class="footer-cta__button footer-cta__button--primary"
            data-popup
            type="button"
            aria-label="Обсудить проект"
          >
            обсудить проект
          </button>
 

        </div>

      </div>

      <!-- RIGHT -->
    <div class="footer-cta__right">

      <!-- CONTACTS -->

      <div class="footer-cta__info">

        <div class="footer-cta__group">

          <span class="footer-cta__caption">
            телефон
          </span>

          <a
            href="tel:89778656828"
            class="footer-cta__contact"
          >
            8 977 865 68 28
          </a>

        </div>

        <div class="footer-cta__group">

          <span class="footer-cta__caption">
            email
          </span>

          <a
            href="mailto:novaya@01vkladka.ru"
            class="footer-cta__contact"
          >
            novaya@01вкладка.рф
          </a>

        </div>

      </div>

      <!-- MESSENGERS -->

      <div class="footer-cta__links">

        <span class="footer-cta__caption">
          месседжеры
        </span>

        <div class="footer-cta__nav">

          <a href="https://t.me/vkladka01" target="_blank" rel="noopener noreferrer">
            Телеграм
          </a>

          <a href="https://vk.com/01vkladka" target="_blank" rel="noopener noreferrer">
            Вконтакте
          </a>

          <a href="https://wa.me/79778656828" target="_blank" rel="noopener noreferrer">
            Ватсапп
          </a>

        </div>

      </div>
 

</div>

    </div>

    <!-- BOTTOM -->

    <div class="footer-cta__bottom">

      <span>
        01вкладка.рф © 2026
      </span>

      <span>
        сайты, которые не закрывают
      </span>
        <button
          type="button"
          class="footer-cta__policy"
          onclick="window.dispatchEvent(new Event('open-policy'))"
        >
          политика конфиденциальности
        </button>

    </div>

  </div>

</section>