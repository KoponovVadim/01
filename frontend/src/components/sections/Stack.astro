---
const processItems = [
  {
    number: '01',
    title: 'Погружение',
    text: 'Изучаем нишу, цели, аудиторию и ограничения. Фиксируем рамки и критерии результата.',
  },

  {
    number: '02',
    title: 'Концепт',
    text: 'Формируем визуальное направление, архитектуру и тон проекта. Согласуем ядро концепции.',
  },

  {
    number: '03',
    title: 'Дизайн',
    text: 'Прорабатываем UX, композицию и адаптив. Доводим до ясных, читаемых интерфейсов.',
  },

  {
    number: '04',
    title: 'Разработка',
    text: 'Собираем на продакшн-стеке, подключаем анимации и функционал. Настраиваем скорость и стабильность.',
  },

  {
    number: '05',
    title: 'Запуск',
    text: 'Тестируем, вносим финальные правки и запускаем. Передаём доступы и готовим к росту.',
  },
];
---

<section class="process" id="process">


  <!-- NOISE -->

  <div class="process__noise"></div>

  <div class="container">

    <!-- TOP -->

    <div class="process__top">

      <div class="process__badge">
        <span></span>
        процесс работы
      </div>

      <div class="process__head">

        <h2 class="process__title">
          Как создаётся
          <br />
          ваша вкладка
        </h2>

        <p class="process__description">
          Прозрачный процесс: вы видите статус,
          решения и результат на каждом этапе.
        </p>

      </div>

    </div>

    <!-- GRID -->

    <div class="process__grid">

      {processItems.map((item) => (

        <article class="process-card">

          <div class="process-card__number">
            {item.number}
          </div>

          <h3 class="process-card__title">
            {item.title}
          </h3>

          <p class="process-card__text">
            {item.text}
          </p>

        </article>

      ))}

    </div>

    <!-- BOTTOM -->

    <div class="process__bottom">

      <div class="process__bottom-content">

        <span class="process__bottom-title">
          Всегда на связи
        </span>

        <p class="process__bottom-text">
          Вы знаете статус проекта на каждом этапе.
          Без бюрократии и лишних терминов — только решения и результат.
        </p>

      </div>

      <a
        href="#contacts"
        class="process__button"
      >
        обсудить проект

        <svg viewBox="0 0 24 24" fill="none">
          <path
            d="M5 12H19"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
          />

          <path
            d="M12 5L19 12L12 19"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>

      </a>

    </div>

  </div>

</section>