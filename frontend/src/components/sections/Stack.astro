---
const processItems = [
  {
    number: '01',
    title: 'Погружение',
    text: 'Изучаем нишу, цели, аудиторию и задачи проекта. Анализируем конкурентов и собираем всё, что важно для старта.',
  },

  {
    number: '02',
    title: 'Концепт',
    text: 'Формируем визуальное направление, архитектуру и характер будущего сайта. Показываем общее видение.',
  },

  {
    number: '03',
    title: 'Дизайн',
    text: 'Прорабатываем интерфейсы, композицию и адаптив. Создаём удобный и сильный пользовательский опыт.',
  },

  {
    number: '04',
    title: 'Разработка',
    text: 'Верстаем проект на современном стеке, подключаем анимации и функционал. Собираем всё в единое целое.',
  },

  {
    number: '05',
    title: 'Запуск',
    text: 'Тестируем, вносим финальные правки и публикуем проект. Подключаем домен, формы и готовим сайт к росту.',
  },
];
---

<section class="process" id="process">

  <!-- BG -->

  <div class="process__bg"></div>

  <!-- GLOW -->

  <div class="process__glow"></div>

  <!-- NOISE -->

  <div class="process__noise"></div>

  <div class="container">

    <!-- TOP -->

    <div class="process__top">

      <div class="process__badge">
        <span></span>
        процесс работы
      </div>

      <div class="process__head">

        <h2 class="process__title">
          Как создаётся
          <br />
          ваша вкладка
        </h2>

        <p class="process__description">
          Прозрачный процесс, в котором вы всегда понимаете,
          что происходит и на каком этапе мы находимся.
        </p>

      </div>

    </div>

    <!-- GRID -->

    <div class="process__grid">

      {processItems.map((item) => (

        <article class="process-card">

          <div class="process-card__number">
            {item.number}
          </div>

          <h3 class="process-card__title">
            {item.title}
          </h3>

          <p class="process-card__text">
            {item.text}
          </p>

        </article>

      ))}

    </div>

    <!-- BOTTOM -->

    <div class="process__bottom">

      <div class="process__bottom-content">

        <span class="process__bottom-title">
          Всегда на связи
        </span>

        <p class="process__bottom-text">
          Вы знаете, что происходит с проектом на каждом этапе.
          Без лишней бюрократии и сложных терминов — только понятный результат.
        </p>

      </div>

      <a
        href="#contact"
        class="process__button"
      >
        обсудить проект

        <svg viewBox="0 0 24 24" fill="none">
          <path
            d="M5 12H19"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
          />

          <path
            d="M12 5L19 12L12 19"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>

      </a>

    </div>

  </div>

</section>