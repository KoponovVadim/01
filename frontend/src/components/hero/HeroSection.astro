---
import heroImage from '@assets/images/hero_main.webp';
---

<section class="hero">

  <!-- BACKGROUND -->

  <div class="hero__background">

    <img
      src={heroImage.src}
      alt=""
      loading="eager"
      decoding="async"
    />

    <!-- FLOATING UI -->

    <div class="hero__floaters" aria-hidden="true">

      <div class="hero-float hero-float--score">
        <span class="hero-float__label">Lighthouse</span>
        <strong class="hero-float__value">98 / 100</strong>
      </div>

      <div class="hero-float hero-float--speed">
        <span class="hero-float__label">Средний запуск</span>
        <strong class="hero-float__value">5–12 дней</strong>
      </div>
 
    </div>

  </div>

  <!-- OVERLAYS -->

  <div class="hero__overlay"></div>

  <div class="hero__noise"></div>

  <!-- GRID FLOOR -->

  <div class="hero__floor"></div>

  <div class="container">

    <div class="hero__layout">

      <!-- LEFT -->

      <div class="hero__content">

        <div class="hero__badge">

          <span></span>

          digital-студия

        </div>

        <h1 class="hero__title">
          ВКЛАДКА,
          <br />
          КОТОРУЮ
          <br />
          НЕ ЗАКРОЮТ.
        </h1>

        <div class="hero__subtitle">
          Пока не купят.
        </div>

        <p class="hero__description">
          Проектируем продуктовые сайты и интерфейсы
          с ясными сценариями и чистой визуальной системой.
        </p>

        <div class="hero__actions">

          <a
            href="#calculator"
            class="hero__button hero__button--primary"
          >
            рассчитать проект
          </a>

          <a
            href="#projects"
            class="hero__button hero__button--secondary"
          >
            смотреть кейсы
          </a>

        </div>

      </div>

    </div>

  </div>

</section>