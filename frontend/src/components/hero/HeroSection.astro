---
import heroImage from '@assets/images/hero_main.webp';
---

<section class="hero">

  <!-- BACKGROUND -->

  <div class="hero__background">

    <img
      src={heroImage.src}
      alt=""
      loading="eager"
      decoding="async"
    />

  </div>

  <!-- OVERLAYS -->

  <div class="hero__overlay"></div>

  <div class="hero__noise"></div>

  <!-- GRID FLOOR -->

  <div class="hero__floor"></div>

  <div class="container">

    <div class="hero__layout">

      <!-- LEFT -->

      <div class="hero__content">

        <div class="hero__badge">

          <span></span>

          digital-студия

        </div>

        <h1 class="hero__title">
          ВКЛАДКА,
          <br />
          КОТОРУЮ
          <br />
          НЕ ЗАКРОЮТ.
        </h1>

        <div class="hero__subtitle">
          Пока не купят.
        </div>

        <p class="hero__description">
          Создаём сайты и интерфейсы,
          которые ощущаются как digital-продукт,
          а не очередной шаблонный лендинг.
        </p>

        <div class="hero__actions">

          <a
            href="#calculator"
            class="hero__button hero__button--primary"
          >
            рассчитать проект
          </a>

          <a
            href="#projects"
            class="hero__button hero__button--secondary"
          >
            смотреть кейсы
          </a>

        </div>

      </div>
 

      <!-- RIGHT -->

      <div class="hero__stats">

        <div class="hero-stat">

          <span class="hero-stat__label">
            активные проекты
          </span>

          <strong class="hero-stat__value">
            12
          </strong>

          <span class="hero-stat__meta">
            в production
          </span>

          <div class="hero-stat__graph"></div>

        </div>

        <div class="hero-stat">

          <span class="hero-stat__label">
            запуск проекта
          </span>

          <strong class="hero-stat__value">
            7 дней
          </strong>

          <span class="hero-stat__meta">
            от концепта до релиза
          </span>
 

        </div>

        <div class="hero-stat">

          <span class="hero-stat__label">
            стек проекта
          </span>

          <strong class="hero-stat__value">
            Astro + Vue
          </strong>

          <span class="hero-stat__meta">
            современный frontend
          </span>

          <div class="hero-stat__bars">

            <span></span>
            <span></span>
            <span></span>
            <span></span>

          </div>

        </div>

        <div class="hero-stat">

          <span class="hero-stat__label">
            анимация
          </span>

          <strong class="hero-stat__value">
            GSAP motion
          </strong>

          <span class="hero-stat__meta">
            плавные интерфейсы
          </span>

          <div class="hero-stat__circle"></div>

        </div>

      </div>

    </div>

  </div>

</section>