---
import stackBg from '@assets/images/stack_bg.webp';
---

<section class="stack" id="stack">

  <!-- BACKGROUND -->

  <div class="stack__background">

    <img
      src={stackBg.src}
      alt=""
      loading="lazy"
      decoding="async"
    />

  </div>

  <!-- NOISE -->

  <div class="stack__noise"></div>

  <div class="container">

    <!-- TOP -->

    <div class="stack__top">

      <span class="stack__eyebrow">
        технологии
      </span>

      <h2 class="stack__title">
        СТЕК,<br />
        НА КОТОРОМ<br />
        СОБИРАЕМ ПРОЕКТЫ
      </h2>

      <p class="stack__description">
        Быстрые интерфейсы, плавная анимация,
        стабильный деплой и современная frontend-архитектура.
      </p>

    </div>

    <!-- GRID -->

    <div class="stack__grid">

      <!-- ASTRO -->

      <article class="stack-card">

        <div class="stack-card__icon">

          <svg
            viewBox="0 0 256 256"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M167.072 179.775C160.544 187.859 147.424 192.384 136.384 192.384C119.168 192.384 107.328 183.616 107.328 170.048C107.328 158.976 113.728 151.232 126.272 147.68C132.672 145.856 141.952 144.832 151.04 143.616L152.864 143.36C162.272 142.112 171.072 140.896 177.184 138.752L167.072 179.775Z"
              fill="currentColor"
            />

            <path
              d="M128 20L27.2 208.352H67.84L87.616 159.296C95.872 165.504 108.992 169.6 123.52 169.6C146.56 169.6 165.568 159.264 171.2 143.328L188.16 208.352H228.8L128 20Z"
              fill="currentColor"
            />
          </svg>

        </div>

        <div class="stack-card__content">

          <span class="stack-card__title">
            Astro
          </span>

          <span class="stack-card__meta">
            ultra-fast frontend architecture
          </span>

        </div>

      </article>

      <!-- VUE -->

      <article class="stack-card">

        <div class="stack-card__icon">

          <svg
            viewBox="0 0 261 226"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M156.6 0L130.5 45.2L104.4 0H0L130.5 226L261 0H156.6Z"
              fill="currentColor"
            />

            <path
              d="M156.6 0L130.5 45.2L104.4 0H54.2L130.5 132L206.8 0H156.6Z"
              fill="#05070B"
            />
          </svg>

        </div>

        <div class="stack-card__content">

          <span class="stack-card__title">
            Vue
          </span>

          <span class="stack-card__meta">
            reactive interface layer
          </span>

        </div>

      </article>

      <!-- GSAP -->

      <article class="stack-card">

        <div class="stack-card__icon">

          <svg
            viewBox="0 0 256 256"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M58 170C58 120 90 86 138 86C168 86 191 98 205 118L173 138C164 126 152 119 138 119C113 119 95 138 95 170C95 202 113 221 140 221C162 221 177 209 181 188H141V157H221V175C221 224 188 256 139 256C88 256 58 221 58 170Z"
              fill="currentColor"
            />
          </svg>

        </div>

        <div class="stack-card__content">

          <span class="stack-card__title">
            GSAP
          </span>

          <span class="stack-card__meta">
            cinematic motion system
          </span>

        </div>

      </article>

      <!-- GIT -->

      <article class="stack-card">

        <div class="stack-card__icon">

          <svg
            viewBox="0 0 97 97"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M92.7 44.4L52.6 4.3C50.1 1.8 46 1.8 43.5 4.3L35.2 12.6L45.8 23.2C48.3 22.3 51.3 22.9 53.3 24.9C55.4 27 56 30 55 32.6L65.2 42.8C67.8 41.9 70.9 42.5 72.9 44.6C75.8 47.5 75.8 52.2 72.9 55.1C70 58 65.3 58 62.4 55.1C60.2 52.9 59.7 49.7 60.8 47L51.3 37.5V62.4C52 62.8 52.7 63.3 53.3 63.9C56.2 66.8 56.2 71.5 53.3 74.4C50.4 77.3 45.7 77.3 42.8 74.4C39.9 71.5 39.9 66.8 42.8 63.9C43.5 63.2 44.4 62.6 45.3 62.2V37.1C44.4 36.7 43.5 36.1 42.8 35.4C40.6 33.2 40.1 30 41.2 27.3L30.8 16.9L4.3 43.4C1.8 45.9 1.8 50 4.3 52.5L44.4 92.6C46.9 95.1 51 95.1 53.5 92.6L92.7 53.4C95.2 50.9 95.2 46.9 92.7 44.4Z"
              fill="currentColor"
            />
          </svg>

        </div>

        <div class="stack-card__content">

          <span class="stack-card__title">
            Git
          </span>

          <span class="stack-card__meta">
            version control workflow
          </span>

        </div>

      </article>

      <!-- SCSS -->

      <article class="stack-card">

        <div class="stack-card__icon">

          <svg
            viewBox="0 0 512 512"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M255.6 43.1C147.6 43.1 61.7 99.7 61.7 169.3C61.7 212.8 89.9 250.8 132.9 273.6C123.9 305.2 96.5 339.8 52.1 355.5C97.1 361.8 131.2 346.6 156.3 321.1C186.1 329.2 219.8 333.5 255.6 333.5C363.6 333.5 449.5 276.9 449.5 207.3C449.5 137.7 363.6 43.1 255.6 43.1ZM197.8 236.6C183.4 250.8 163.7 257.5 138.7 257.5C113.9 257.5 95.1 249.8 82.5 234.4L105.7 211.8C115.3 223.2 127.2 228.9 141.5 228.9C149.7 228.9 156.4 227.1 161.7 223.4C167 219.7 169.6 214.8 169.6 208.7C169.6 202.8 167.4 198.1 163 194.7C158.7 191.3 151.1 188.1 140.3 185.1C123.2 180.5 110.6 174.8 102.5 168C94.4 161.2 90.3 151.3 90.3 138.3C90.3 124.2 95.5 112.6 105.8 103.6C116.2 94.7 129.9 90.2 147 90.2C168.6 90.2 186.4 96.8 200.3 110.1L178.5 132.7C169.8 124.4 159.3 120.3 147 120.3C139.8 120.3 134.1 121.9 129.9 125C125.8 128.2 123.7 132.4 123.7 137.8C123.7 143.5 126.1 148 130.9 151.2C135.8 154.5 144 157.7 155.5 160.8C172.2 165.4 184.2 171.1 191.5 177.9C198.9 184.7 202.5 194.7 202.5 208C202.5 220.2 197.6 229.8 187.8 236.6Z"
              fill="currentColor"
            />
          </svg>

        </div>

        <div class="stack-card__content">

          <span class="stack-card__title">
            SCSS
          </span>

          <span class="stack-card__meta">
            scalable style architecture
          </span>

        </div>

      </article>

      <!-- DOCKER -->

      <article class="stack-card">

        <div class="stack-card__icon">

          <svg
            viewBox="0 0 256 181"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M246.4 70.4C240.5 66.2 226.5 63.6 216.1 65.2C214.7 54.7 205.5 45.5 194.8 40.7L189.8 38.6L186.6 43.1C182.2 49.6 180.1 59.8 181.1 69.4C181.4 72 182.1 74.7 183.1 77.3C179.4 79.4 172.4 82.3 161.6 82.3H9.8C7.3 96.1 9.2 113.3 20.4 128.5C35.2 148.7 62.9 159 102.5 159C188.6 159 237.4 120.7 247.3 85.2C247.6 84 247.9 82.7 248.2 81.5L249.1 76.7L246.4 70.4ZM33.1 69.4H57.6V45H33.1V69.4ZM63.9 69.4H88.4V45H63.9V69.4ZM94.7 69.4H119.2V45H94.7V69.4ZM125.5 69.4H150V45H125.5V69.4ZM63.9 38.7H88.4V14.2H63.9V38.7ZM94.7 38.7H119.2V14.2H94.7V38.7ZM125.5 38.7H150V14.2H125.5V38.7ZM156.3 69.4H180.8V45H156.3V69.4Z"
              fill="currentColor"
            />
          </svg>

        </div>

        <div class="stack-card__content">

          <span class="stack-card__title">
            Docker Compose
          </span>

          <span class="stack-card__meta">
            deployment environment
          </span>

        </div>

      </article>

    </div>

  </div>

</section>