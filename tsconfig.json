{
  "extends": "astro/tsconfigs/strict",

  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],

  "exclude": [
    "dist"
  ],

  "compilerOptions": {
    "jsx": "preserve",

    "baseUrl": ".",

    "paths": {
      "@/*": ["src/*"],
      "@components/*": ["src/components/*"],
      "@layouts/*": ["src/layouts/*"],
      "@styles/*": ["src/styles/*"],
      "@assets/*": ["src/assets/*"]
    }
  }
}